# MongoDB
MONGODB_URL=mongodb://mongodb:27017
DATABASE_NAME=complaint_db

# JWT
SECRET_KEY=your-super-secret-key-change-this-in-production-abc123xyz
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# Cloudinary (for image uploads - get free account at cloudinary.com)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Redis
REDIS_URL=redis://redis:6379/0

# Celery
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# Email (optional - for notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password

# Escalation timing
ESCALATION_DAYS=3
ESCALATION_LEVEL1_DAYS=2
ESCALATION_LEVEL2_DAYS=5